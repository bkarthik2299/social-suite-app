# Browser-exposed Vite variables.
# These are safe to expose only when Supabase RLS is enabled and correctly scoped.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
VITE_APP_ENV=development
# Optional. Set this in production if auth emails should always return to one canonical public app URL.
# Example: https://app.yourdomain.com
VITE_AUTH_REDIRECT_ORIGIN=
VITE_POSTHOG_PROJECT_TOKEN=phc_your_posthog_project_token
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_ENABLE_LOCAL=false

# Optional local-only compatibility for the existing Password Vault.
# This is browser-exposed and should not be treated as a true server secret.
# Plan a server-side/per-user vault encryption migration before production use.
VITE_VAULT_ENCRYPTION_KEY=replace-with-local-development-key

# Server-side only. Do not prefix these with VITE_ and do not use them in browser code.
# Configure these in Supabase Edge Function secrets and Trigger.dev secrets instead.
OPENROUTER_API_KEY=
TAVILY_API_KEY=
SUPADATA_API_KEY=
FIRECRAWL_API_KEY=
TRIGGER_SECRET_KEY=
AI_DEFAULT_MODEL=deepseek/deepseek-v4-flash
AI_FAST_MODEL=deepseek/deepseek-v4-flash
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell
